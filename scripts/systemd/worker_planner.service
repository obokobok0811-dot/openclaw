[Unit]
Description=OpenClaw Worker - Planner
After=network.target

[Service]
Type=simple
User=andy
WorkingDirectory=/Users/andy/.openclaw/workspace/agents/worker_planner
ExecStart=/usr/bin/env python3 /Users/andy/.openclaw/workspace/agents/worker_planner/app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
