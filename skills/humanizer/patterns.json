  "structural_patterns": {
    "em_dash_to_comma": {
      "description": "Replace em dashes with commas or parentheses. Em dashes are heavily overused in AI output.",
      "pattern": "\\s*[—–]\\s*",
      "replacement": ", "
    },
    "rule_of_three": {
      "description": "Detect and flag lists of exactly three adjectives/items in a row, a common AI rhythm pattern.",
      "pattern": "\\b(\\w+),\\s+(\\w+),\\s+and\\s+(\\w+)\\b",
      "note": "Flag for human review. Not all triads are bad, but AI defaults to three items when listing."
    },
    "participle_tail": {
      "description": "Trailing '-ing' phrases that add superficial analysis. Common AI tell per Wikipedia.",
      "pattern": ",\\s+(highlighting|underscoring|emphasizing|ensuring|reflecting|symbolizing|contributing to|cultivating|fostering|showcasing|demonstrating|illustrating|signaling|reinforcing|solidifying|cementing|encapsulating|epitomizing|embodying|championing|spearheading)\\s+",
      "action": "remove_to_end_of_sentence"
    },
    "sentence_opener_repetition": {
      "description": "AI often starts consecutive sentences or paragraphs with the same structure (e.g., 'This...', 'The...', 'It...'). Flag when 3+ consecutive sentences share an opener.",
      "action": "flag_for_review"
    }
  },
  "formatting_patterns": {
    "emoji_in_headers": {
      "description": "AI decorates section headers with emoji. Remove emoji from headers.",
      "pattern": "^(#{1,6}\\s*)([\\p{Emoji_Presentation}\\p{Extended_Pictographic}]+\\s*)+",
      "action": "strip_emoji_from_header"
    },
    "excessive_bold": {
      "description": "AI bolds too many phrases for emphasis. Flag when more than 20% of sentences contain bold text.",
      "action": "flag_for_review"
    },
    "list_after_colon": {
      "description": "AI pattern: ending a sentence with a colon then a bulleted list for every point. Not always wrong, but flag when it happens 3+ times in a short passage.",
      "action": "flag_for_review"
    }
  }
}
